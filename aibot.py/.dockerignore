# Виртуальное окружение (в контейнере создастся своё)
.venv/
venv/
env/

# Кэш Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Локальные базы данных
# (Чтобы контейнер при старте создал чистую БД через init_db)
*.db
*.sqlite3

# Переменные окружения
# (В идеале передаются через настройки хостинга, а не копируются файлом)
.env
*.env

# IDE и настройки редакторов
.vscode/
.idea/
*.swp
*.swo

# Система и логи
*.log
.DS_Store
Thumbs.db
.git/
.gitignore
Dockerfile